@app.route('/api/v2/key/generate', methods=['POST'])
async def generate_api_key():
    """Generate new API key"""
    data = request.get_json()
    admin_key = data.get('admin_key', '')
    
    # Verify admin key
    if admin_key != Config.ADMIN_API_KEY:
        return jsonify({'error': 'Invalid admin key'}), 403
    
    user_id = data.get('user_id', secrets.token_hex(8))
    tier = data.get('tier', 'free')
    
    key_info = key_manager.generate_api_key(user_id, tier)
    
    return jsonify({
        'success': True,
        **key_info
    })

@app.route('/api/v2/key/validate')
@require_api_key
def validate_api_key():
    """Validate API key and return info"""
    return jsonify({
        'valid': True,
        'permissions': request.api_key_data['permissions'],
        'tier': request.api_key_data['tier'],
        'rate_limit': request.api_key_data['rate_limit']
    })

@app.route('/api/v2/key/revoke', methods=['POST'])
@require_permission('admin')
def revoke_api_key():
    """Revoke an API key"""
    data = request.get_json()
    key_to_revoke = data.get('api_key', '')
    
    if key_manager.revoke_key(key_to_revoke):
        return jsonify({'success': True, 'message': 'API key revoked'})
    return jsonify({'error': 'Key not found'}), 404

