@app.route('/search', methods=['POST'])
@limiter.limit("30 per minute")
async def web_search():
    """Web search endpoint"""
    try:
        data = request.get_json()
        query = data.get('query', '').strip()
        
        if not query:
            return jsonify({'error': 'Query is required'}), 400
        
        if len(query) > 200:
            return jsonify({'error': 'Query too long'}), 400
        
        # Search all engines
        results = await search_engine.search_all(query, limit=20)
        
        # Get AI summary
        ai_summary = await ai_service.get_summary(query, results['merged_results'][:10])
        
        return jsonify({
            'success': True,
            'query': query,
            'ai_summary': ai_summary,
            'results': results['merged_results'],
            'stats': {
                'total_engines': results['total_engines_searched'],
                'successful': results['successful_engines'],
                'results_count': len(results['merged_results']),
                'timestamp': results['timestamp']
            }
        })
        
    except Exception as e:
        return jsonify({'error': str(e)}), 500

# ===================== API ROUTES =====================

@app.route('/api/v2/search')
@require_permission('web')
@limiter.limit("100 per hour")
async def api_search():
    """API: Search endpoint"""
    query = request.args.get('q', '')
    limit = int(request.args.get('limit', 20))
    engines = request.args.get('engines', 'all')
    
    if not query:
        return jsonify({
            'error': 'Missing query parameter',
            'usage': '/api/v2/search?q=your_query&limit=20'
        }), 400
    
    try:
        if engines == 'all':
            results = await search_engine.search_all(query, limit=min(limit, 20))
        else:
            engine_list = engines.split(',')
            tasks = []
            for engine in engine_list[:20]:
                tasks.append(search_engine.search_single_engine(engine.strip(), query))
            engine_results = await asyncio.gather(*tasks)
            results = {
                'query': query,
                'results': engine_results,
                'merged_results': search_engine.merge_results(engine_results)
            }
        
        # Add API metadata
        results['api_version'] = Config.VERSION
        results['rate_limit_remaining'] = request.headers.get('X-RateLimit-Remaining', 'N/A')
        
        return jsonify(results)
        
    except Exception as e:
        return jsonify({'error': str(e)}), 500

@app.route('/api/v2/ai/analyze')
@require_permission('ai')
@limiter.limit("50 per hour")
async def api_ai_analyze():
    """API: AI-powered search analysis"""
    query = request.args.get('q', '')
    
    if not query:
        return jsonify({'error': 'Missing query parameter'}), 400
    
    try:
        # Perform quick search for context
        search_results = await search_engine.search_all(query, limit=5)
        
        # Get AI analysis
        analysis = await ai_service.get_summary(query, search_results['merged_results'][:10])
        
        return jsonify({
            'query': query,
            'analysis': analysis,
            'model': 'gpt-4o-mini',
            'timestamp': datetime.now().isoformat()
        })
        
    except Exception as e:
        return jsonify({'error': str(e)}), 500

