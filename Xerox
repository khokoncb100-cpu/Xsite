# API Key Management System
class APIKeyManager:
    """Unified API Key Manager for both AI and Web Search"""
    
    def __init__(self):
        self.keys_db = {}  # In production, use a real database
        self.initialize_admin_key()
    
    def initialize_admin_key(self):
        """Create admin API key"""
        admin_key = Config.ADMIN_API_KEY
        self.keys_db[admin_key] = {
            'user_id': 'admin',
            'tier': 'enterprise',
            'created_at': datetime.now(),
            'expires_at': None,
            'rate_limit': 10000,
            'permissions': ['ai', 'web', 'admin', 'docs'],
            'active': True
        }
    
    def generate_api_key(self, user_id: str, tier: str = 'free') -> Dict:
        """Generate a new unified API key"""
        api_key = f"ms_{secrets.token_urlsafe(24)}"
        
        tier_configs = {
            'free': {
                'rate_limit': 100,
                'expires_in': timedelta(days=30),
                'permissions': ['web']
            },
            'pro': {
                'rate_limit': 1000,
                'expires_in': timedelta(days=365),
                'permissions': ['ai', 'web']
            },
            'enterprise': {
                'rate_limit': 10000,
                'expires_in': None,
                'permissions': ['ai', 'web', 'admin', 'docs']
            }
        }
        
        config = tier_configs.get(tier, tier_configs['free'])
        expires_at = datetime.now() + config['expires_in'] if config['expires_in'] else None
        
        self.keys_db[api_key] = {
            'user_id': user_id,
            'tier': tier,
            'created_at': datetime.now(),
            'expires_at': expires_at,
            'rate_limit': config['rate_limit'],
            'permissions': config['permissions'],
            'active': True
        }
        
        return {
            'api_key': api_key,
            'tier': tier,
            'permissions': config['permissions'],
            'rate_limit': config['rate_limit'],
            'expires_at': expires_at.isoformat() if expires_at else 'Never'
        }
    
    def validate_key(self, api_key: str) -> Optional[Dict]:
        """Validate API key and return permissions"""
        key_data = self.keys_db.get(api_key)
        
        if not key_data:
            return None
        
        if not key_data['active']:
            return None
        
        if key_data['expires_at'] and key_data['expires_at'] < datetime.now():
            return None
        
        return key_data
    
    def check_permission(self, api_key: str, permission: str) -> bool:
        """Check if API key has specific permission"""
        key_data = self.validate_key(api_key)
        if not key_data:
            return False
        return permission in key_data['permissions']
    
    def revoke_key(self, api_key: str) -> bool:
        """Revoke an API key"""
        if api_key in self.keys_db:
            self.keys_db[api_key]['active'] = False
            return True
        return False

# Initialize API Key Manager
key_manager = APIKeyManager()

# Decorator for API authentication
def require_api_key(f):
    """Decorator to require API key for endpoints"""
    @wraps(f)
    def decorated_function(*args, **kwargs):
        api_key = request.headers.get('X-API-Key') or request.args.get('api_key')
        
        if not api_key:
            return jsonify({
                'error': 'API key is required',
                'message': 'Please provide API key in X-API-Key header or api_key parameter',
                'documentation': '/docs'
            }), 401
        
        key_data = key_manager.validate_key(api_key)
        if not key_data:
            return jsonify({
                'error': 'Invalid or expired API key',
                'message': 'Get your API key at /get-api-key'
            }), 403
        
        # Add key data to request context
        request.api_key_data = key_data
        return f(*args, **kwargs)
    return decorated_function

def require_permission(permission):
    """Decorator to require specific permission"""
    def decorator(f):
        @wraps(f)
        @require_api_key
        def decorated_function(*args, **kwargs):
            if permission not in request.api_key_data['permissions']:
                return jsonify({
                    'error': 'Insufficient permissions',
                    'required': permission,
                    'your_permissions': request.api_key_data['permissions']
                }), 403
            return f(*args, **kwargs)
        return decorated_function
    return decorator

# Meta Search Engine Class
class MetaSearchEngine:
    """Powerful meta search engine with 20+ sources"""
    
    def __init__(self):
        self.session = None
        self.cache = search_cache
    
    async def get_session(self):
        """Get or create HTTP session"""
        if not self.session:
            self.session = httpx.AsyncClient(
                timeout=Config.TIMEOUT,
                headers={'User-Agent': ua.random}
            )
        return self.session
    
    async def search_single_engine(self, engine_name: str, query: str) -> Dict:
        """Search a single engine"""
        engine = Config.SEARCH_ENGINES.get(engine_name)
        if not engine:
            return {'error': 'Engine not found'}
        
        cache_key = f"{engine_name}:{query}"
        if cache_key in self.cache:
            return self.cache[cache_key]
        
        try:
            session = await self.get_session()
            url = engine['url'].format(query=quote(query))
            
            response = await session.get(url, follow_redirects=True)
            
            if response.status_code != 200:
                return {'engine': engine_name, 'results': [], 'error': f'HTTP {response.status_code}'}
            
            soup = BeautifulSoup(response.text, 'lxml')
            results = self.parse_results(engine['parser'], soup, engine_name)
            
            result_data = {
                'engine': engine_name,
                'name': engine['name'],
                'icon': engine['icon'],
                'color': engine['color'],
                'category': engine['category'],
                'results': results,
                'timestamp': datetime.now().isoformat()
            }
            
            self.cache[cache_key] = result_data
            return result_data
            
        except Exception as e:
            return {
                'engine': engine_name,
                'name': engine['name'],
                'icon': engine['icon'],
                'color': engine['color'],
                'results': [],
                'error': str(e)
            }
    
    def parse_results(self, parser_type: str, soup: BeautifulSoup, engine: str) -> List[Dict]:
        """Parse search results based on engine type"""
        results = []
        
        try:
            if parser_type == 'google':
                results = self.parse_google(soup)
            elif parser_type == 'bing':
                results = self.parse_bing(soup)
            elif parser_type == 'duckduckgo':
                results = self.parse_duckduckgo(soup)
            elif parser_type == 'yahoo':
                results = self.parse_yahoo(soup)
            else:
                results = self.parse_generic(soup)
        except Exception as e:
            print(f"Parsing error for {engine}: {e}")
        
        return results[:10]  # Limit to 10 results per engine
    
    def parse_google(self, soup: BeautifulSoup) -> List[Dict]:
        """Parse Google search results"""
        results = []
        for g in soup.select('.g'):
            link = g.select_one('a')
            title = g.select_one('h3')
            snippet = g.select_one('.VwiC3b') or g.select_one('.st')
            
            if link and title:
                url = link.get('href', '')
                if url.startswith('/url?'):
                    from urllib.parse import parse_qs
                    parsed = parse_qs(urlparse(url).query)
                    url = parsed.get('q', [url])[0]
                
                results.append({
                    'title': title.get_text(strip=True),
                    'url': url,
                    'snippet': snippet.get_text(strip=True) if snippet else '',
                    'source': 'Google'
                })
        return results
    
    def parse_bing(self, soup: BeautifulSoup) -> List[Dict]:
        """Parse Bing search results"""
        results = []
        for item in soup.select('.b_algo'):
            title = item.select_one('h2 a')
            snippet = item.select_one('.b_caption p')
            
            if title:
                results.append({
                    'title': title.get_text(strip=True),
                    'url': title.get('href', ''),
                    'snippet': snippet.get_text(strip=True) if snippet else '',
                    'source': 'Bing'
                })
        return results
    
    def parse_duckduckgo(self, soup: BeautifulSoup) -> List[Dict]:
        """Parse DuckDuckGo results"""
        results = []
        for item in soup.select('.result'):
            title = item.select_one('.result__title')
            link = item.select_one('.result__url')
            snippet = item.select_one('.result__snippet')
            
            if title:
                results.append({
                    'title': title.get_text(strip=True),
                    'url': link.get('href', '') if link else '',
                    'snippet': snippet.get_text(strip=True) if snippet else '',
                    'source': 'DuckDuckGo'
                })
        return results
    
    def parse_yahoo(self, soup: BeautifulSoup) -> List[Dict]:
        """Parse Yahoo results"""
        results = []
        for item in soup.select('.algo-sr'):
            title = item.select_one('h3')
            link = item.select_one('a')
            snippet = item.select_one('.compText')
            
            if title and link:
                results.append({
                    'title': title.get_text(strip=True),
                    'url': link.get('href', ''),
                    'snippet': snippet.get_text(strip=True) if snippet else '',
                    'source': 'Yahoo'
                })
        return results
    
    def parse_generic(self, soup: BeautifulSoup) -> List[Dict]:
        """Generic parser for other engines"""
        results = []
        for link in soup.select('a[href]')[:20]:
            href = link.get('href', '')
            text = link.get_text(strip=True)
            
            if text and len(text) > 10 and href.startswith('http'):
                results.append({
                    'title': text,
                    'url': href,
                    'snippet': '',
                    'source': 'Web'
                })
        return results
    
    async def search_all(self, query: str, limit: int = 5) -> Dict:
        """Search all engines concurrently"""
        tasks = []
        engines_to_search = list(Config.SEARCH_ENGINES.keys())[:limit]
        
        for engine in engines_to_search:
            tasks.append(self.search_single_engine(engine, query))
        
        all_results = await asyncio.gather(*tasks)
        
        # Organize results
        organized = {
            'query': query,
            'timestamp': datetime.now().isoformat(),
            'total_engines_searched': len(all_results),
            'successful_engines': sum(1 for r in all_results if r.get('results')),
            'results': all_results,
            'merged_results': self.merge_results(all_results)
        }
        
        return organized
    
    def merge_results(self, all_results: List[Dict]) -> List[Dict]:
        """Merge and deduplicate results from all engines"""
        seen_urls = set()
        merged = []
        
        for engine_result in all_results:
            for result in engine_result.get('results', []):
                url = result.get('url', '')
                if url and url not in seen_urls:
                    seen_urls.add(url)
                    result['engine'] = engine_result.get('name', 'Unknown')
                    result['engine_icon'] = engine_result.get('icon', '')
                    result['engine_color'] = engine_result.get('color', '#000')
                    merged.append(result)
        
        # Sort by relevance (simple version - can be enhanced with ML)
        return merged[:Config.MAX_SEARCH_RESULTS]
    
    async def close(self):
        """Close HTTP session"""
        if self.session:
            await self.session.aclose()

# AI Service
class AIService:
    """AI-powered search enhancement using OpenRouter"""
    
    def __init__(self):
        self.api_key = Config.OPENROUTER_API_KEY
        self.url = Config.OPENROUTER_URL
    
    async def get_summary(self, query: str, results: List[Dict]) -> str:
        """Generate AI summary of search results"""
        if not self.api_key:
            return "AI service not configured. Please set OPENROUTER_API_KEY."
        
        try:
            # Prepare context from results
            context = "\n".join([
                f"- {r.get('title', '')}: {r.get('snippet', '')}"
                for r in results[:5]
            ])
            
            headers = {
                "Authorization": f"Bearer {self.api_key}",
                "HTTP-Referer": request.host_url if request else "http://localhost:5000",
                "Content-Type": "application/json"
            }
            
            payload = {
                "model": "openai/gpt-4o-mini",
                "messages": [
                    {
                        "role": "system",
                        "content": """You are an expert search assistant. Provide:
1. A concise summary of the search results
2. Key facts and findings
3. Direct answer to the query if possible
4. Related topics for further exploration

Format the response in Markdown with clear sections."""
                    },
                    {
                        "role": "user",
                        "content": f"Query: {query}\n\nSearch Results:\n{context}\n\nProvide comprehensive analysis."
                    }
                ],
                "temperature": 0.3,
                "max_tokens": 1000
            }
            
            async with httpx.AsyncClient() as client:
                response = await client.post(
                    self.url,
                    headers=headers,
                    json=payload,
                    timeout=15
                )
                
                if response.status_code == 200:
                    result = response.json()
                    return result['choices'][0]['message']['content']
                else:
                    return f"AI analysis unavailable (Error: {response.status_code})"
                    
        except Exception as e:
            return f"AI analysis error: {str(e)}"
    
    async def answer_question(self, question: str) -> Dict:
        """Direct question answering"""
        if not self.api_key:
            return {'error': 'AI service not configured'}
        
        try:
            headers = {
                "Authorization": f"Bearer {self.api_key}",
                "HTTP-Referer": request.host_url if request else "http://localhost:5000",
                "Content-Type": "application/json"
            }
            
            payload = {
                "model": "openai/gpt-4o-mini",
                "messages": [
                    {
                        "role": "system",
                        "content": "You are a knowledgeable assistant. Provide accurate, detailed answers."
                    },
                    {
                        "role": "user",
                        "content": question
                    }
                ],
                "temperature": 0.3,
                "max_tokens": 500
            }
            
            async with httpx.AsyncClient() as client:
                response = await client.post(
                    self.url,
                    headers=headers,
                    json=payload,
                    timeout=10
                )
                
                if response.status_code == 200:
                    result = response.json()
                    return {
                        'question': question,
                        'answer': result['choices'][0]['message']['content'],
                        'model': 'gpt-4o-mini',
                        'timestamp': datetime.now().isoformat()
                    }
                    
        except Exception as e:
            return {'error': str(e)}

