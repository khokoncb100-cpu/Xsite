        <div class="results-container" id="resultsContainer"></div>
    </div>
    
    <!-- Footer -->
    <div class="footer">
        <p>MetaSearch Pro v2.0.0 | Powered by 20+ Search Engines & AI</p>
        <p style="margin-top: 8px; font-size: 14px;">
            <a href="/docs" style="color: rgba(255,255,255,0.9);">API Docs</a> | 
            <a href="/get-api-key" style="color: rgba(255,255,255,0.9);">Get API Key</a>
        </p>
    </div>
    
    <script>
        let currentResults = null;
        
        function toggleMenu() {
            document.getElementById('dropdownMenu').classList.toggle('show');
        }
        
        // Close menu when clicking outside
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.three-dots-menu')) {
                document.getElementById('dropdownMenu').classList.remove('show');
            }
        });
        
        function clearSearch() {
            document.getElementById('searchInput').value = '';
            document.getElementById('clearBtn').style.display = 'none';
            document.getElementById('resultsContainer').innerHTML = '';
            document.getElementById('aiSummaryCard').classList.remove('show');
            document.getElementById('statsBar').classList.remove('show');
        }
        
        // Show/hide clear button
        document.getElementById('searchInput').addEventListener('input', function(e) {
            document.getElementById('clearBtn').style.display = 
                e.target.value.length > 0 ? 'flex' : 'none';
        });
        
        async function performSearch() {
            const query = document.getElementById('searchInput').value.trim();
            if (!query) return;
            
            // Show loading
            document.getElementById('loadingContainer').classList.add('show');
            document.getElementById('resultsContainer').innerHTML = '';
            document.getElementById('aiSummaryCard').classList.remove('show');
            document.getElementById('statsBar').classList.remove('show');
            document.getElementById('dropdownMenu').classList.remove('show');
            
            const startTime = performance.now();
            
            try {
                const response = await fetch('/search', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({query: query})
                });
                
                const data = await response.json();
                const endTime = performance.now();
                const searchTime = ((endTime - startTime) / 1000).toFixed(2);
                
                if (data.success) {
                    currentResults = data;
                    displayResults(data.results);
                    displayAISummary(data.ai_summary);
                    displayStats(data.results.length, searchTime, data.stats.successful);
                }
            } catch (error) {
                console.error('Search error:', error);
                document.getElementById('resultsContainer').innerHTML = 
                    '<div style="color:white;text-align:center;padding:40px;">' +
                    '<i class="fas fa-exclamation-triangle" style="font-size:48px;"></i>' +
                    '<p>Search failed. Please try again.</p></div>';
            } finally {
                document.getElementById('loadingContainer').classList.remove('show');
            }
        }
        
        function displayResults(results) {
            const container = document.getElementById('resultsContainer');
            
            if (!results || results.length === 0) {
                container.innerHTML = '<div style="color:white;text-align:center;padding:40px;">' +
                    '<i class="fas fa-search" style="font-size:48px;"></i>' +
                    '<p>No results found</p></div>';
                return;
            }
            
            container.innerHTML = results.map((result, index) => `
                <div class="result-card" style="animation-delay: ${index * 0.05}s;">
                    <div class="result-source">
                        <img src="${result.engine_icon || 'https://www.google.com/favicon.ico'}" 
                             class="source-icon" 
                             onerror="this.src='https://www.google.com/favicon.ico'">
                        <span class="source-name">${result.engine || 'Web'}</span>
                    </div>
                    <a href="${result.url}" target="_blank" class="result-title">
                        ${result.title}
                    </a>
                    <span class="result-url">${result.url}</span>
                    <p class="result-snippet">${result.snippet || 'No description available'}</p>
                </div>
            `).join('');
        }
        
        function displayAISummary(summary) {
            if (summary) {
                document.getElementById('aiContent').innerHTML = summary;
                document.getElementById('aiSummaryCard').classList.add('show');
            }
        }
        
        function displayStats(count, time, sources) {
            document.getElementById('resultsCount').textContent = count;
            document.getElementById('searchTime').textContent = time;
            document.getElementById('sourcesCount').textContent = sources;
            document.getElementById('statsBar').classList.add('show');
        }
        
        function startVoiceSearch() {
            if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
                const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                const recognition = new SpeechRecognition();
                recognition.lang = 'en-US';
                recognition.start();
                
                recognition.onresult = function(event) {
                    const transcript = event.results[0][0].transcript;
                    document.getElementById('searchInput').value = transcript;
                    performSearch();
                };
            } else {
                alert('Voice search not supported in this browser');
            }
        }
        
        function shareSearch() {
            if (navigator.share && currentResults) {
                navigator.share({
                    title: 'MetaSearch Results',
                    text: `Search results for: ${currentResults.query}`,
                    url: window.location.href
                });
            }
        }
        
        function exportResults() {
            if (!currentResults || !currentResults.results) return;
            
            let csv = 'Title,URL,Snippet,Source\\n';
            currentResults.results.forEach(r => {
                csv += `"${r.title}","${r.url}","${r.snippet}","${r.engine}"\\n`;
            });
            
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'search-results.csv';
            a.click();
        }
        
        function toggleTheme() {
            document.body.classList.toggle('dark-theme');
        }
        
        function showSettings() {
            alert('Settings: Search engines, region, and preferences can be customized.');
        }
        
        function showAbout() {
            alert('MetaSearch Pro v2.0.0\\nUnified search across 20+ engines\\nPowered by AI (GPT-4o Mini)\\n\\n© 2024 MetaSearch Team');
        }
    </script>
</body>
</html>
'''

